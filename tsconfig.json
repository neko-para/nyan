{
    "extends": ["@tsconfig/node24/tsconfig.json"],
    "compilerOptions": {
        "noEmit": true,
        "module": "ES2022",
        "moduleResolution": "bundler",
        "resolveJsonModule": true,
        "allowArbitraryExtensions": true,
        "verbatimModuleSyntax": true,
        "allowImportingTsExtensions": true,
        "types": ["@types/node"]
    },
    "include": ["logger/**/*.ts"]
}
