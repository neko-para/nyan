{
    "version": 5,
    "cmakeMinimumRequired": {
        "major": 3,
        "minor": 30,
        "patch": 0
    },
    "configurePresets": [
        {
            "name": "MacNinja",
            "displayName": "MacNinja",
            "description": "MacNinja",
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/build"
        },
        {
            "name": "LinuxNinja",
            "displayName": "LinuxNinja",
            "description": "LinuxNinja",
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/build",
            "cacheVariables": {
                "CMAKE_TOOLCHAIN_FILE": "${sourceDir}/i686-elf-linux.cmake"
            }
        },
        {
            "name": "WinNinja",
            "displayName": "WinNinja",
            "description": "WinNinja",
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/build",
            "cacheVariables": {
                "CMAKE_TOOLCHAIN_FILE": "${sourceDir}/i686-elf-win-with-sysroot.cmake"
            }
        }
    ],
    "buildPresets": [
        {
            "name": "MacNinja",
            "displayName": "MacNinja",
            "description": "MacNinja",
            "configurePreset": "MacNinja",
            "configuration": "Release",
            "jobs": 16
        },
        {
            "name": "LinuxNinja",
            "displayName": "LinuxNinja",
            "description": "LinuxNinja",
            "configurePreset": "LinuxNinja",
            "configuration": "Release",
            "jobs": 16
        },
        {
            "name": "WinNinja",
            "displayName": "WinNinja",
            "description": "WinNinja",
            "configurePreset": "WinNinja",
            "configuration": "Release",
            "jobs": 16
        }
    ]
}
